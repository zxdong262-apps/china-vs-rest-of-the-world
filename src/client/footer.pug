//- Footer Component
footer.footer
  .container
    .footer-content
      .footer-section
        h3= locale.footer.title
        ul.footer-links
          each source, key in data.links.dataSources
            li
              a(href=source.url, target='_blank', rel='noopener')= source.name
      .footer-section
        h3= locale.footer.tools
        ul.footer-links
          each source, key in data.links.tools
            li
              a(href=source.url, target='_blank', rel='noopener')= source.name
      .footer-section
        h3= locale.footer.project
        ul.footer-links
          each source, key in data.links.project
            li
              a(href=source.url, target='_blank', rel='noopener')= source.name
      .footer-section
        h3= locale.nav.language
        ul.footer-links
          li
            a(href='/') English
          li
            a(href='/zh_CN') 中文
    .footer-bottom
      p= locale.footer.disclaimer
      p &copy; 2024 China vs Rest of the World. #{locale.footer.copyright}
